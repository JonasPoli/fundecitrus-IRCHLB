{% extends 'admin/base.html.twig' %}

{% block body %}
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa-solid fa-paper-plane" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
                Newsletter
            </h1>
            <p class="page-subtitle">Editar inscrição</p>
        </div>
        <a href="{{ path('admin_newsletter_request_index') }}" class="btn-secondary">
            <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            Voltar
        </a>
    </div>
        
    {{ include('admin/newsletter_request/_form.html.twig') }}
    
    <form method="post" action="{{ path('admin_newsletter_request_delete', {'id': newsletter_request.id}) }}" onsubmit="return confirm('Tem certeza de que quer apagar este registro?');" class="text-right mt-6">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ newsletter_request.id) }}">
        <button type="submit" class="btn-danger">
            <i class="fa-solid fa-trash" aria-hidden="true"></i>
            Excluir
        </button>
    </form>
{% endblock %}
