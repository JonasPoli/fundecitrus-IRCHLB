{% extends 'admin/base.html.twig' %}

{% block title %}Usuários{% endblock %}
{% block page_title %}Usuários{% endblock %}

{% block breadcrumbs %}
    {% set breadcrumbs = [
        { label: 'Dashboard', route: 'admin_dash' },
        { label: 'Usuários',  route: null }
    ] %}
    {{ include('admin/_partials/breadcrumbs.html.twig', { breadcrumbs: breadcrumbs }) }}
{% endblock %}

{% block body %}

{# ── Page Header ───────────────────────────────────────────────────────────── #}
<div class="page-header">
    <h1 class="page-title">Usuários</h1>
    <a href="{{ path('app_admin_user_new') }}"
       class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-white text-sm font-medium hover:bg-primary-dark transition-colors shadow-sm shadow-primary/20"
       aria-label="Criar novo usuário">
        <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
        Novo Usuário
    </a>
</div>

{# ── Users Table ───────────────────────────────────────────────────────────── #}
<div class="admin-card">
    <div class="responsive-table">
        <table class="admin-table" aria-label="Lista de usuários cadastrados">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Nome</th>
                    <th scope="col">Username</th>
                    <th scope="col">E-mail</th>
                    <th scope="col">Perfis</th>
                    <th scope="col">Criado em</th>
                    <th scope="col">
                        <span class="sr-only">Ações</span>
                    </th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td class="text-slate-400 dark:text-slate-500 tabular-nums">{{ user.id }}</td>
                        <td class="font-medium">
                            <div class="flex items-center gap-2">
                                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-primary-light flex items-center justify-center text-xs font-bold" aria-hidden="true">
                                    {{ (user.name ?? user.username)|first|upper }}
                                </span>
                                {{ user.name ?? user.username }}
                            </div>
                        </td>
                        <td class="text-slate-500 dark:text-slate-400 font-mono text-xs">{{ user.username }}</td>
                        <td>
                            {% if user.email %}
                                <a href="mailto:{{ user.email }}" class="text-primary dark:text-primary-light hover:underline text-xs">
                                    {{ user.email }}
                                </a>
                            {% else %}
                                <span class="text-slate-400 dark:text-slate-500 text-xs">—</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="flex flex-wrap gap-1">
                                {% for role in user.roles %}
                                    {% if role != 'ROLE_USER' %}
                                        {% if role == 'ROLE_ADMIN' %}
                                            <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300">
                                                {{ role|role_label }}
                                            </span>
                                        {% else %}
                                            <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300">
                                                {{ role|role_label }}
                                            </span>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                                <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">
                                    Usuário
                                </span>
                            </div>
                        </td>
                        <td class="text-slate-500 dark:text-slate-400 text-xs tabular-nums">
                            {% if user.createdAt %}
                                <time datetime="{{ user.createdAt|date('Y-m-d') }}">
                                    {{ user.createdAt|date('d/m/Y') }}
                                </time>
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td class="text-right">
                            <a href="{{ path('app_admin_user_edit', {'id': user.id}) }}"
                               class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
                               aria-label="Editar usuário {{ user.name ?? user.username }}">
                                <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                                Editar
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="py-12 text-center text-slate-400 dark:text-slate-500">
                            <i class="fa-solid fa-users-slash" class="text-2xl mb-2 block" aria-hidden="true"></i>
                            <p>Nenhum usuário cadastrado.</p>
                            <a href="{{ path('app_admin_user_new') }}" class="text-primary dark:text-primary-light hover:underline text-sm mt-1 inline-block">
                                Criar o primeiro usuário
                            </a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}