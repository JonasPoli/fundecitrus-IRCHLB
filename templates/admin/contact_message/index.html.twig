{% extends 'admin/base.html.twig' %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Fale Conosco        </h1>
        <p class="page-subtitle"></p>
    </div>
    <div>
        <a href="{{ path('app_admin_contact_message_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Adicionar
        </a>
    </div>
</div>

<div class="admin-card">
    
    <table class="admin-table">
        <thead>
            <tr>
                <th>Contato</th>
                <th>Assunto</th>
                <th>Data de Envio</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for contact_message in contact_messages %}
                <tr>
                    <td>
                        <div class="font-medium text-slate-900 dark:text-white">{{ contact_message.firstName }} {{ contact_message.lastName }}</div>
                        <div class="text-xs text-slate-500">{{ contact_message.email }}</div>
                    </td>
                    <td>{{ contact_message.subject }}</td>
                    <td>{{ contact_message.createdAt ? contact_message.createdAt|date('d/m/Y H:i') : '' }}</td>
                    <td>
                        {% if contact_message.status == 'New' %}
                            <span class="badge badge-danger">Nova</span>
                        {% else %}
                            <span class="badge badge-success">{{ contact_message.status }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('app_admin_contact_message_edit', {'id': contact_message.id}) }}" class="btn-secondary" aria-label="Editar {{ contact_message.subject }}" title="Editar {{ contact_message.subject }}">
                            <i class="fa-solid fa-pen" aria-hidden="true"></i>
                            Editar
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Nenhum registro</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>

    <script>
        {% if contact_messages is not empty %}
            $(document).ready(function () {
            $('.admin-table').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json',
                },
                pageLength: 10,
                lengthMenu: [[5, 10, 25, -1], [5, 10, 25, 'Todos']],
                order: [[0, 'asc']],
            });
        {% endif %}
    });
    </script>
{% endblock %}