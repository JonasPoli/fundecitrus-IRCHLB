{% extends 'admin/base.html.twig' %}

{% block body %}
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
                Editar Organizador
            </h1>
            <p class="page-subtitle">Altere as informações do organizador.</p>
        </div>
        <a href="{{ path('admin_organizer_index') }}" class="btn-secondary">
            <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            Voltar
        </a>
    </div>
        
    {{ include('admin/organizer/_form.html.twig') }}
    
    <form method="post" action="{{ path('admin_organizer_delete', {'id': organizer.id}) }}" onsubmit="return confirm('Tem certeza de que deseja excluir este organizador?');" class="text-right mt-6">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ organizer.id) }}">
        <button class="btn-danger">
            <i class="fa-solid fa-trash" aria-hidden="true"></i>
            Excluir
        </button>
    </form>
{% endblock %}
