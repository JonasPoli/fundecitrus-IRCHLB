{% extends 'admin/base.html.twig' %}

{% block body %}
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa-solid fa-images" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
                Editar Banner
            </h1>
            <p class="page-subtitle">Modifique as informações do banner selecionado.</p>
        </div>
        <a href="{{ path('admin_home_banner_index') }}" class="btn-secondary">
            <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            Voltar
        </a>
    </div>
        
    {{ include('admin/home_banner/_form.html.twig') }}
    
    <form method="post" action="{{ path('admin_home_banner_delete', {'id': home_banner.id}) }}" onsubmit="return confirm('Tem certeza de que deseja apagar este banner?');" class="text-right mt-6">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ home_banner.id) }}">
        <button type="submit" class="btn-danger">
            <i class="fa-solid fa-trash" aria-hidden="true"></i>
            Excluir
        </button>
    </form>
{% endblock %}
