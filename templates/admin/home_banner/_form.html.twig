{{ form_start(form) }}
    <div class="admin-card space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.mainTitle) }}
            {{ form_row(form.subtitle) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.eventDate) }}
            <div>
                {{ form_row(form.image) }}
                {% if home_banner is defined and home_banner.image and home_banner.image.imageName %}
                    <div class="mt-2">
                        <span class="text-xs text-slate-500 block mb-1">Visualização da imagem atual:</span>
                        <img src="{{ asset('uploads/' ~ home_banner.image.imageName) }}" alt="Preview" class="w-32 h-20 object-cover rounded shadow border border-slate-200">
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.description1) }}
            {{ form_row(form.description) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.button1Text) }}
            {{ form_row(form.button1Link) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.button2Text) }}
            {{ form_row(form.button2Link) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.position) }}
            {{ form_row(form.isActive) }}
        </div>
    </div>
    
    <div class="w-full text-right mt-6">
        <button type="submit" class="btn-primary">
            <i class="fa-solid fa-check" aria-hidden="true"></i>
            Salvar
        </button>
    </div>
{{ form_end(form) }}
