<!DOCTYPE html>
<html lang="pt-BR" class="{{ app.user and is_granted('ROLE_PREVIOUS_ADMIN') ? 'impersonating' : '' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} · {{ site_name|default('WAB Admin') }}</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#0f1117">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    {{ importmap('app') }}

    {% block stylesheets %}{% endblock %}

    <script>
        (function(){
            const t = localStorage.getItem('theme');
            const dark = t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches);
            document.documentElement.classList.toggle('dark', dark);
        })();
    </script>
</head>
<body class="admin-body" data-controller="nav">

{% if app.user and is_granted('ROLE_PREVIOUS_ADMIN') %}
    <div class="impersonate-banner" role="alert">
        <span>
            <i class="fa-solid fa-mask" aria-hidden="true"></i>
            Você está navegando como <strong>{{ app.user.userIdentifier }}</strong>
        </span>
        <a href="{{ path('app_admin_user_index', {'_switch_user': '_exit'}) }}"
        class="impersonate-exit"
        aria-label="Sair da impersonação e voltar ao seu usuário">
            <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
            Sair da impersonação
        </a>
    </div>
{% endif %}

{# ══════════════════════════════════════════════════════════════════════════
   SIDEBAR
   ══════════════════════════════════════════════════════════════════════════ #}
<aside class="admin-sidebar"
       id="admin-sidebar"
       data-nav-target="sidebar"
       aria-label="Menu de navegação">

    {# ── Brand ─────────────────────────────────────────────────────────── #}
    <div class="sidebar-brand">
        <img src="{{ asset('images/logo.png') }}" alt="IRCHLB 2027" class="sidebar-brand-logo">
    </div>

    {# ── Nav ───────────────────────────────────────────────────────────── #}
    <nav class="sidebar-nav" aria-label="Navegação principal">

        <div class="sidebar-section-label">Principal</div>

        <a {{nav_item_class('admin_dash')}} href="{{ path('admin_dash') }}">
            <i class="fa-solid fa-house" aria-hidden="true"></i>
            <span>Dashboard</span>
        </a>

        <a {{nav_item_class('app_admin_user')}} href="{{ path('app_admin_user_index') }}">
            <i class="fa-solid fa-users" aria-hidden="true"></i>
            <span>Usuários</span>
        </a>

        <a {{nav_item_class('app_admin_exemplo')}} href="{{ path('app_admin_exemplo_index') }}">
            <i class="fa-solid fa-rectangle-list" aria-hidden="true"></i>
            <span>DataTable + Form</span>
            <span class="nav-badge">Demo</span>
        </a>

        <a {{nav_item_class('app_admin_icones')}} href="{{ path('app_admin_icones_index') }}">
            <i class="fa-solid fa-palette" aria-hidden="true"></i>
            <span>Ícones</span>
            <span class="nav-badge">Demo</span>
        </a>

        <div class="sidebar-section-label">Configuração</div>
        <a {{nav_item_class('app_admin_event_config')}} href="{{ path('app_admin_event_config_index') }}">
            <i class="fa-solid fa-gear" aria-hidden="true"></i>
            <span>Evento Geral</span>
        </a>
        <a {{nav_item_class('app_admin_statistic_item')}} href="{{ path('app_admin_statistic_item_index') }}">
            <i class="fa-solid fa-chart-simple" aria-hidden="true"></i>
            <span>Estatísticas Home</span>
        </a>
        <a {{nav_item_class('admin_home_banner')}} href="{{ path('admin_home_banner_index') }}">
            <i class="fa-solid fa-images" aria-hidden="true"></i>
            <span>Home Banners</span>
        </a>
        <a {{nav_item_class('app_admin_page_content')}} href="{{ path('app_admin_page_content_index') }}">
            <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
            <span>Páginas Extras</span>
        </a>
        <a {{nav_item_class('app_admin_committee_member')}} href="{{ path('app_admin_committee_member_index') }}">
            <i class="fa-solid fa-users-gear" aria-hidden="true"></i>
            <span>Comissão</span>
        </a>
        <a {{nav_item_class('admin_organizer')}} href="{{ path('admin_organizer_index') }}">
            <i class="fa-solid fa-rectangle-list" aria-hidden="true"></i>
            <span>Organizadores</span>
        </a>

        <div class="sidebar-section-label">Inscrições & Prazos</div>
        <a {{nav_item_class('app_admin_registration_batch')}} href="{{ path('app_admin_registration_batch_index') }}">
            <i class="fa-solid fa-ticket" aria-hidden="true"></i>
            <span>Lotes e Tarifas</span>
        </a>
        <a {{nav_item_class('app_admin_thematic_group')}} href="{{ path('app_admin_thematic_group_index') }}">
            <i class="fa-solid fa-calendar-day" aria-hidden="true"></i>
            <span>Cronograma Papers</span>
        </a>

        <div class="sidebar-section-label">Programação</div>
        <a {{nav_item_class('app_admin_speaker')}} href="{{ path('app_admin_speaker_index') }}">
            <i class="fa-solid fa-microphone" aria-hidden="true"></i>
            <span>Palestrantes</span>
        </a>
        <a {{nav_item_class('app_admin_event_day')}} href="{{ path('app_admin_event_day_index') }}">
            <i class="fa-solid fa-calendar-days" aria-hidden="true"></i>
            <span>Dias de Evento</span>
        </a>
        <a {{nav_item_class('app_admin_venue_room')}} href="{{ path('app_admin_venue_room_index') }}">
            <i class="fa-solid fa-door-open" aria-hidden="true"></i>
            <span>Salas e Auditórios</span>
        </a>
        <a {{nav_item_class('app_admin_agenda_activity')}} href="{{ path('app_admin_agenda_activity_index') }}">
            <i class="fa-solid fa-clock" aria-hidden="true"></i>
            <span>Atividades da Agenda</span>
        </a>

        <div class="sidebar-section-label">Parcerias</div>
        <a {{nav_item_class('app_admin_sponsorship_tier')}} href="{{ path('app_admin_sponsorship_tier_index') }}">
            <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
            <span>Cotas de Patrocínio</span>
        </a>
        <a {{nav_item_class('app_admin_sponsor')}} href="{{ path('app_admin_sponsor_index') }}">
            <i class="fa-solid fa-handshake" aria-hidden="true"></i>
            <span>Patrocinadores</span>
        </a>
        <a {{nav_item_class('app_admin_sponsorship_inquiry')}} href="{{ path('app_admin_sponsorship_inquiry_index') }}">
            <i class="fa-solid fa-envelope-open-text" aria-hidden="true"></i>
            <span>Interesse em Cotas</span>
        </a>

        <div class="sidebar-section-label">Guia Local</div>
        <a {{nav_item_class('app_admin_airport_guide')}} href="{{ path('app_admin_airport_guide_index') }}">
            <i class="fa-solid fa-plane" aria-hidden="true"></i>
            <span>Aeroportos</span>
        </a>
        <a {{nav_item_class('app_admin_partner_hotel')}} href="{{ path('app_admin_partner_hotel_index') }}">
            <i class="fa-solid fa-hotel" aria-hidden="true"></i>
            <span>Hotéis Parceiros</span>
        </a>
        <a {{nav_item_class('app_admin_restaurant_recommendation')}} href="{{ path('app_admin_restaurant_recommendation_index') }}">
            <i class="fa-solid fa-utensils" aria-hidden="true"></i>
            <span>Gastronomia</span>
        </a>

        <div class="sidebar-section-label">Suporte</div>
        <a {{nav_item_class('app_admin_contact_message')}} href="{{ path('app_admin_contact_message_index') }}">
            <i class="fa-solid fa-envelope" aria-hidden="true"></i>
            <span>Fale Conosco</span>
        </a>
        <a {{nav_item_class('admin_newsletter_request')}} href="{{ path('admin_newsletter_request_index') }}">
            <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
            <span>Newsletter</span>
        </a>
        <a {{nav_item_class('app_admin_faq_category')}} href="{{ path('app_admin_faq_category_index') }}">
            <i class="fa-solid fa-folder-open" aria-hidden="true"></i>
            <span>Categorias FAQ</span>
        </a>
        <a {{nav_item_class('app_admin_faq_item')}} href="{{ path('app_admin_faq_item_index') }}">
            <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
            <span>Perguntas FAQ</span>
        </a>

        {% block sidebar_links %}{% endblock %}

    </nav>

    {# ── Footer ────────────────────────────────────────────────────────── #}
    <div class="sidebar-footer">
        <div class="sidebar-user">
            <div class="sidebar-user-avatar" aria-hidden="true"
                 style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#4f8ef7,#a855f7);color:white;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0">
                {{ (app.user.name ?? app.user.userIdentifier)|first|upper }}
            </div>
            <div class="sidebar-user-info" style="min-width:0;flex:1">
                <span class="sidebar-user-name">{{ app.user.name ?? app.user.userIdentifier }}</span>
                <span class="sidebar-user-role">Administrador</span>
            </div>
        </div>
        <a href="{{ path('app_logout') }}"
                class="theme-toggle"
                aria-label="Sair"
                title="Sair">
            <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
        </a>
    </div>

</aside>

{# ══════════════════════════════════════════════════════════════════════════
   MAIN WRAPPER
   ══════════════════════════════════════════════════════════════════════════ #}
<div class="admin-main" id="admin-main">

    {# ── Mobile topbar ─────────────────────────────────────────────────── #}
    <header class="admin-topbar" aria-label="Cabeçalho">
        <button type="button"
                class="topbar-menu-btn"
                data-action="click->nav#toggleSidebar"
                aria-expanded="false"
                aria-controls="admin-sidebar"
                aria-label="Abrir menu">
            <i class="fa-solid fa-bars" aria-hidden="true"></i>
        </button>

        <div class="topbar-breadcrumbs">
            {% block breadcrumbs %}{% endblock %}
        </div>

        <div class="topbar-actions">
            <button type="button"
                    class="topbar-icon-btn"
                    id="theme-btn-topbar"
                    onclick="document.documentElement.classList.contains('dark') ? lightMode() : darkMode(); updateThemeIcons()"
                    aria-label="Alternar tema"
                    title="Alternar tema">
                <i class="fa-regular fa-sun" id="theme-icon-topbar" aria-hidden="true"></i>
            </button>
        </div>
    </header>

    {% if app.flashes|length > 0 %}
        <div class="flash-container" aria-live="polite">
            {{ include('admin/_partials/flash.html.twig') }}
        </div>
    {% endif %}

    <main class="admin-content" id="main-content">
        {% block body %}{% endblock %}
    </main>

</div>

{# ── Mobile overlay ────────────────────────────────────────────────────── #}
<div class="sidebar-overlay" data-nav-target="overlay" data-action="click->nav#closeSidebar" aria-hidden="true"></div>

{% block javascripts %}{% endblock %}

</body>
</html>
