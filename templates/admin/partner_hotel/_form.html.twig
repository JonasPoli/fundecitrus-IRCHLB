{{ form_start(form) }}
    <div class="admin-card space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.name) }}
            {{ form_row(form.stars) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.bookingCode) }}
            {{ form_row(form.bookingLink) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.address) }}
            {{ form_row(form.contact) }}
        </div>
        <div>
            {{ form_row(form.description) }}
        </div>
        <div>
            {{ form_row(form.image) }}
            {% if partner_hotel is defined and partner_hotel.image and partner_hotel.image.imageName %}
                <div class="mt-2">
                    <span class="text-xs text-slate-500 block mb-1">Visualização da imagem atual:</span>
                    <img src="{{ asset('uploads/' ~ partner_hotel.image.imageName) }}" alt="Preview" class="w-48 h-32 object-cover rounded shadow border border-slate-200">
                </div>
            {% endif %}
        </div>
        {{ form_row(form.position) }}
    </div>
    
    <div class="w-full text-right mt-6">
        <button type="submit" class="btn-primary" id="submit-btn">
            <i class="fa-solid fa-check" aria-hidden="true"></i>
            Salvar
        </button>
    </div>
{{ form_end(form) }}