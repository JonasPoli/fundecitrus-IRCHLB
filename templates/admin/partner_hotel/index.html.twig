{% extends 'admin/base.html.twig' %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Hotéis Parceiros        </h1>
        <p class="page-subtitle"></p>
    </div>
    <div>
        <a href="{{ path('app_admin_partner_hotel_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Adicionar
        </a>
    </div>
</div>

<div class="admin-card">
    
    <table class="admin-table">
        <thead>
            <tr>
                                    <th></th>
                                    <th>ID</th>
                                    <th>Imagem</th>
                                    <th>Nome</th>
                                    <th>Estrelas</th>
                                    <th>Código de Reserva</th>
                                    <th>Link de Reserva</th>
                                    <th>Endereço</th>
                                    <th>Contato</th>
                                <th></th>
            </tr>
        </thead>
        <tbody id="partner-hotel-sortable">
            {% for partner_hotel in partner_hotels %}
                <tr class="sortable-row" data-id="{{ partner_hotel.id }}">
                                                                    <td style="width: 30px; text-align: center;"><i class="fa-solid fa-grip-vertical" style="cursor: grab; color: #a1a1aa;"></i></td>
                                                                    <td>{{ partner_hotel.id }}</td>
                                                                    <td>
                                                                        {% if partner_hotel.image and partner_hotel.image.imageName %}
                                                                            <img src="{{ asset('uploads/' ~ partner_hotel.image.imageName) }}" alt="{{ partner_hotel.name }}" style="max-width: 60px; max-height: 40px; object-fit: cover; border-radius: 4px;">
                                                                        {% else %}
                                                                            <span style="font-size: 11px; opacity: 0.6;">-</span>
                                                                        {% endif %}
                                                                    </td>
                                                                                            <td>{{ partner_hotel.name }}</td>
                                                                                            <td>{{ partner_hotel.stars }}</td>
                                                                                            <td>{{ partner_hotel.bookingCode ?? '-' }}</td>
                                                                                            <td>
                                                                                                {% if partner_hotel.bookingLink %}
                                                                                                    <a href="{{ partner_hotel.bookingLink }}" target="_blank" class="text-primary hover:underline text-xs">Link</a>
                                                                                                {% else %}
                                                                                                    <span class="text-xs opacity-50">-</span>
                                                                                                {% endif %}
                                                                                            </td>
                                                                                            <td>{{ partner_hotel.address }}</td>
                                                                                            <td>{{ partner_hotel.contact }}</td>
                                                                 <td><a href="{{ path('app_admin_partner_hotel_edit', {'id': partner_hotel.id}) }}" class="btn-secondary" aria-label="Editar {{ partner_hotel.name }}" title="Editar {{ partner_hotel.name }}"><i class="fa-solid fa-pen" aria-hidden="true"></i>Editar</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="10">Nenhum registro</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>

    <script>
        {% if partner_hotels is not empty %}
            $(document).ready(function () {
            $('.admin-table').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json',
                },
                ordering: false,
                pageLength: 10,
                lengthMenu: [[5, 10, 25, -1], [5, 10, 25, 'Todos']],
            });
        {% endif %}
    });
    </script>
    {{ include('admin/_sortable_script.html.twig', {
        tbody_id: 'partner-hotel-sortable',
        reorder_url: path('app_admin_reorder', { entityName: 'PartnerHotel' })
    }) }}
{% endblock %}