{{ form_start(form) }}
    <div class="admin-card space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.title) }}
            {{ form_row(form.slug) }}
        </div>
        
        <div class="wab-field mb-4">
            {{ form_label(form.content) }}
            
            <link rel="stylesheet" href="https://cdn.quilljs.com/1.3.7/quill.snow.css">
            <style>
                .ql-container {
                    font-family: inherit;
                    font-size: 14px;
                }
                .ql-editor {
                    min-height: 250px;
                    background: #fff;
                    color: #333;
                }
            </style>
            
            <div id="quill-editor" class="border border-slate-300 rounded-b"></div>
            
            {# Campo oculto real que sincroniza com o Quill #}
            <div class="hidden">
                {{ form_widget(form.content) }}
            </div>
            
            {{ form_errors(form.content) }}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.updatedAt) }}
        </div>
    </div>
    
    <div class="w-full text-right mt-6">
        <button type="submit" class="btn-primary" id="submit-btn">
            <i class="fa-solid fa-check" aria-hidden="true"></i>
            Salvar
        </button>
    </div>
{{ form_end(form) }}

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const quill = new Quill('#quill-editor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link', 'clean']
                ]
            }
        });

        // Preenche o editor Quill com o valor inicial do textarea do Symfony
        const textarea = document.querySelector('[name*="[content]"]');
        if (textarea) {
            quill.root.innerHTML = textarea.value;
        }

        // Sincroniza o conteúdo do Quill com o textarea antes de submeter
        const form = document.querySelector('form');
        form.addEventListener('submit', () => {
            if (textarea) {
                textarea.value = quill.root.innerHTML;
            }
        });
    });
</script>