{% extends 'admin/base.html.twig' %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Páginas Extras        </h1>
        <p class="page-subtitle"></p>
    </div>
    <div>
        <a href="{{ path('app_admin_page_content_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Adicionar
        </a>
    </div>
</div>

<div class="admin-card">
    
    <table class="admin-table">
        <thead>
            <tr>
                                    <th>ID</th>
                                    <th>Identificador (Slug)</th>
                                    <th>Título</th>
                                    <th>Conteúdo</th>
                                    <th>Última Atualização</th>
                                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for page_content in page_contents %}
                <tr>
                                                                    <td>{{ page_content.id }}</td>
                                                                                            <td>{{ page_content.slug }}</td>
                                                                                            <td>{{ page_content.title }}</td>
                                                                                            <td>{{ (page_content.content|slice(0, 20) ~ (page_content.content|length > 20 ? '...' : ''))|raw }}</td>
                                                                                            <td>{{ page_content.updatedAt ? page_content.updatedAt|date('d/m/Y H:i') : '' }}</td>
                                                                 <td><a href="{{ path('app_admin_page_content_edit', {'id': page_content.id}) }}" class="btn-secondary" aria-label="Editar {{ page_content.title }}" title="Editar {{ page_content.title }}"><i class="fa-solid fa-pen" aria-hidden="true"></i>Editar</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Nenhum registro</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>

    <script>
        {% if page_contents is not empty %}
            $(document).ready(function () {
            $('.admin-table').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json',
                },
                pageLength: 10,
                lengthMenu: [[5, 10, 25, -1], [5, 10, 25, 'Todos']],
                order: [[0, 'asc']],
            });
        {% endif %}
    });
    </script>
{% endblock %}