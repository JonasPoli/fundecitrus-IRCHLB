{% extends 'admin/base.html.twig' %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-rectangle-list admin-page-title-icon" aria-hidden="true"></i>
            Membros da Comissão        </h1>
        <p class="page-subtitle"></p>
    </div>
    <div>
        <a href="{{ path('app_admin_committee_member_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Adicionar
        </a>
    </div>
</div>

<div class="admin-card">
    
    <table class="admin-table">
        <thead>
            <tr>
                                    <th></th>
                                    <th>ID</th>
                                    <th>Foto</th>
                                    <th>Nome</th>
                                    <th>Cargo / Função</th>
                                    <th>Instituição</th>
                                    <th>Tipo de Grupo</th>
                                <th></th>
            </tr>
        </thead>
        <tbody id="committee-member-sortable">
            {% for committee_member in committee_members %}
                <tr class="sortable-row" data-id="{{ committee_member.id }}">
                                                                    <td class="admin-table-grip-td"><i class="fa-solid fa-grip-vertical admin-table-grip-icon" aria-hidden="true"></i></td>
                                                                    <td>{{ committee_member.id }}</td>
                                                                    <td>
                                                                        {% if committee_member.image and committee_member.image.imageName %}
                                                                            <img src="{{ asset('uploads/' ~ committee_member.image.imageName) }}" alt="{{ committee_member.name }}" class="admin-table-thumb-round">
                                                                        {% else %}
                                                                            <span style="font-size: 11px; opacity: 0.6;">-</span>
                                                                        {% endif %}
                                                                    </td>
                                                                                            <td>{{ committee_member.name }}</td>
                                                                                            <td>{{ committee_member.role }}</td>
                                                                                            <td>{{ committee_member.institution }}</td>
                                                                                            <td>{{ committee_member.groupType }}</td>
                                                                 <td><a href="{{ path('app_admin_committee_member_edit', {'id': committee_member.id}) }}" class="btn-secondary" aria-label="Editar {{ committee_member.name }}" title="Editar {{ committee_member.name }}"><i class="fa-solid fa-pen" aria-hidden="true"></i>Editar</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8">Nenhum registro</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>

    <script>
        {% if committee_members is not empty %}
            $(document).ready(function () {
            $('.admin-table').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json',
                },
                ordering: false,
                pageLength: 10,
                lengthMenu: [[5, 10, 25, -1], [5, 10, 25, 'Todos']],
            });
        {% endif %}
    });
    </script>
    {{ include('admin/_sortable_script.html.twig', {
        tbody_id: 'committee-member-sortable',
        reorder_url: path('app_admin_reorder', { entityName: 'CommitteeMember' })
    }) }}
{% endblock %}