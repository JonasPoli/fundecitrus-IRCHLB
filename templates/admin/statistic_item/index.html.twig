{% extends 'admin/base.html.twig' %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Estatísticas da Home        </h1>
        <p class="page-subtitle"></p>
    </div>
    <div>
        <a href="{{ path('app_admin_statistic_item_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Adicionar
        </a>
    </div>
</div>

<div class="admin-card">
    
    <table class="admin-table">
        <thead>
            <tr>
                                    <th></th>
                                    <th>Id</th>
                                    <th>Label</th>
                                    <th>Value</th>
                                    <th>IsActive</th>
                                <th></th>
            </tr>
        </thead>
        <tbody id="statistic-item-sortable">
            {% for statistic_item in statistic_items %}
                <tr class="sortable-row" data-id="{{ statistic_item.id }}">
                                                                    <td style="width: 30px; text-align: center;"><i class="fa-solid fa-grip-vertical" style="cursor: grab; color: #a1a1aa;"></i></td>
                                                                    <td>{{ statistic_item.id }}</td>
                                                                                            <td>{{ statistic_item.label }}</td>
                                                                                            <td>{{ statistic_item.value }}</td>
                                                                                            <td>
                                                                                                {% if statistic_item.isActive %}
                                                                                                    <span class="badge badge-success">Ativo</span>
                                                                                                {% else %}
                                                                                                    <span class="badge badge-danger">Inativo</span>
                                                                                                {% endif %}
                                                                                            </td>
                                                                 <td><a href="{{ path('app_admin_statistic_item_edit', {'id': statistic_item.id}) }}" class="btn-secondary" aria-label="Editar {{ statistic_item.label }}" title="Editar {{ statistic_item.label }}"><i class="fa-solid fa-pen" aria-hidden="true"></i>Editar</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Nenhum registro</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>

    <script>
        {% if statistic_items is not empty %}
            $(document).ready(function () {
            $('.admin-table').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json',
                },
                ordering: false,
                pageLength: 10,
                lengthMenu: [[5, 10, 25, -1], [5, 10, 25, 'Todos']],
            });
        {% endif %}
    });
    </script>
    {{ include('admin/_sortable_script.html.twig', {
        tbody_id: 'statistic-item-sortable',
        reorder_url: path('app_admin_reorder', { entityName: 'StatisticItem' })
    }) }}
{% endblock %}