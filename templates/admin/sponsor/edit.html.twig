{% extends 'admin/base.html.twig' %}

{% block body %}
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
                Patrocinadores            </h1>
            <p class="page-subtitle"></p>
        </div>
        <a href="{{ path('app_admin_sponsor_index') }}" class="btn-secondary">
            <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            Voltar
        </a>
    </div>
        
    {{ include('admin/sponsor/_form.html.twig') }}
    
    <form method="post" action="{{ path('app_admin_sponsor_delete', {'id': sponsor.id}) }}" onsubmit="return confirm('Tem certeza de que quer apagar este registro?');" class="text-right mt-6">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ sponsor.id) }}">
            <button type="submit" class="btn-danger">
                <i class="fa-solid fa-trash" aria-hidden="true"></i>
                Excluir
            </button>
        </form>
{% endblock %}
