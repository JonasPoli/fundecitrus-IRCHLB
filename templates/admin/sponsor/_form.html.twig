{{ form_start(form) }}
    <div class="admin-card space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.name) }}
            {{ form_row(form.websiteUrl) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.tier) }}
            {{ form_row(form.standNumber) }}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {{ form_row(form.isExhibitor) }}
            {{ form_row(form.logo) }}
        </div>
        <div>
            {{ form_row(form.description) }}
        </div>
        
        {% if sponsor is defined and sponsor.logo and sponsor.logo.imageName %}
            <div class="mt-2">
                <span class="text-xs text-slate-500 block mb-1">Visualização do logotipo atual:</span>
                <img src="{{ asset('uploads/' ~ sponsor.logo.imageName) }}" alt="Preview" class="w-48 h-32 object-contain rounded shadow border border-slate-200 bg-slate-50">
            </div>
        {% endif %}
        
        {{ form_row(form.position) }}
    </div>
    
    <div class="w-full text-right mt-6">
        <button type="submit" class="btn-primary">
            <i class="fa-solid fa-check" aria-hidden="true"></i>
            Salvar
        </button>
    </div>
{{ form_end(form) }}