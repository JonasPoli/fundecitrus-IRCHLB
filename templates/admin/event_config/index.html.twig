{% extends 'admin/base.html.twig' %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Configurações do Evento        </h1>
        <p class="page-subtitle"></p>
    </div>
    <div>
        <a href="{{ path('app_admin_event_config_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Adicionar
        </a>
    </div>
</div>

<div class="admin-card">
    
    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nome do Local</th>
                <th>Endereço / Cidade</th>
                <th>E-mail de Suporte</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for event_config in event_configs %}
                <tr>
                    <td>{{ event_config.id }}</td>
                    <td>{{ event_config.locationName }}</td>
                    <td>{{ event_config.addressStreet }}, {{ event_config.addressCity }}</td>
                    <td>{{ event_config.supportEmail }}</td>
                    <td><a href="{{ path('app_admin_event_config_edit', {'id': event_config.id}) }}" class="btn-secondary" aria-label="Editar" title="Editar"><i class="fa-solid fa-pen" aria-hidden="true"></i>Editar</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Nenhum registro</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>

    <script>
        {% if event_configs is not empty %}
            $(document).ready(function () {
            $('.admin-table').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json',
                },
                pageLength: 10,
                lengthMenu: [[5, 10, 25, -1], [5, 10, 25, 'Todos']],
                order: [[0, 'asc']],
            });
        {% endif %}
    });
    </script>
{% endblock %}