{% extends 'admin/base.html.twig' %}

{% block body %}
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
                Configurações do Evento            </h1>
            <p class="page-subtitle"></p>
        </div>
        <a href="{{ path('app_admin_event_config_index') }}" class="btn-secondary">
            <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            Voltar à listagem
        </a>
    </div>
        
    {{ include('admin/event_config/_form.html.twig') }}
    
    <form method="post" action="{{ path('app_admin_event_config_delete', {'id': event_config.id}) }}" onsubmit="return confirm('Tem certeza de que quer apagar este registro?');" class="text-right mt-6">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event_config.id) }}">
            <button type="submit" class="btn-danger" id="submit-btn">
                <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                Apagar registro
            </button>
        </form>
{% endblock %}
