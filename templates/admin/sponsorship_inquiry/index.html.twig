{% extends 'admin/base.html.twig' %}

{% block body %}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fa-solid fa-rectangle-list" style="margin-right:8px;color:var(--bm-accent)" aria-hidden="true"></i>
            Contatos de Patrocínio        </h1>
        <p class="page-subtitle"></p>
    </div>
    <div>
        <a href="{{ path('app_admin_sponsorship_inquiry_new') }}" class="btn-primary">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            Adicionar
        </a>
    </div>
</div>

<div class="admin-card">
    
    <table class="admin-table">
        <thead>
            <tr>
                                    <th>Id</th>
                                    <th>Nome da Empresa</th>
                                    <th>Pessoa de Contato</th>
                                    <th>E-mail Corporativo</th>
                                    <th>Área de Interesse</th>
                                    <th>Enviado Em</th>
                                    <th>Status</th>
                                <th></th>
            </tr>

        </thead>
        <tbody>
            {% for sponsorship_inquiry in sponsorship_inquiries %}
                <tr>
                                                                    <td>{{ sponsorship_inquiry.id }}</td>
                                                                                            <td>{{ sponsorship_inquiry.companyName }}</td>
                                                                                            <td>{{ sponsorship_inquiry.contactPerson }}</td>
                                                                                            <td>{{ sponsorship_inquiry.corporateEmail }}</td>
                                                                                            <td>{{ sponsorship_inquiry.interestArea }}</td>
                                                                                            <td>{{ sponsorship_inquiry.createdAt ? sponsorship_inquiry.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                                                                                            <td>{{ sponsorship_inquiry.status }}</td>
                                                                 <td><a href="{{ path('app_admin_sponsorship_inquiry_edit', {'id': sponsorship_inquiry.id}) }}" class="btn-secondary" aria-label="Editar {{ sponsorship_inquiry.companyName }}" title="Editar {{ sponsorship_inquiry.companyName }}"><i class="fa-solid fa-pen" aria-hidden="true"></i>Editar</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8">Nenhum registro</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block javascripts %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>

    <script>
        {% if sponsorship_inquiries is not empty %}
            $(document).ready(function () {
            $('.admin-table').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.8/i18n/pt-BR.json',
                },
                pageLength: 10,
                lengthMenu: [[5, 10, 25, -1], [5, 10, 25, 'Todos']],
                order: [[0, 'asc']],
            });
        {% endif %}
    });
    </script>
{% endblock %}