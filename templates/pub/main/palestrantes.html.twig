{% extends 'pub/base.html.twig' %}

{% block body %}
    <section class="bg-slate-900 text-white py-16 relative overflow-hidden border-b-8 border-secondary">
        {% if event_config and event_config.heroImage and event_config.heroImage.imageName %}
            <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('{{ ('uploads/' ~ event_config.heroImage.imageName)|imagine_filter('banner_hero') }}'); background-color: #004040;"></div>
        {% else %}
            <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('{{ asset('images/hero-bg.jpg') }}'); background-color: #004040;"></div>
        {% endif %}
        <div class="container mx-auto px-6 text-center relative z-10">
            <span class="material-symbols-outlined text-secondary text-5xl mb-4">record_voice_over</span>
            <h1 class="text-4xl md:text-5xl font-bold mb-4">Distinguished Speakers</h1>
            <p class="text-secondary text-lg max-w-2xl mx-auto">Explore the profiles of the globally recognized researchers, exponents, and panel experts actively engaged in presenting at IRCHLB 2027.</p>
        </div>
    </section>

    <!-- Speakers Master Directory -->
    <section class="py-24 bg-slate-50 min-h-screen">
        <div class="container mx-auto px-6">
            {% if speakers is not empty %}
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                    {% for speaker in speakers %}
                        <div class="bg-white rounded-2xl overflow-hidden card-shadow hover-effect group flex flex-col justify-between h-full" data-aos="fade-up" data-aos-delay="{{ (loop.index0 % 4) * 100 }}">
                            <div>
                                <div class="relative overflow-hidden">
                                    {% if speaker.image and speaker.image.imageName %}
                                        <img src="{{ ('uploads/' ~ speaker.image.imageName)|imagine_filter('avatar') }}" alt="{{ speaker.name }}" width="400" height="400" loading="{{ loop.index <= 4 ? 'eager' : 'lazy' }}"
                                            class="w-full h-80 object-cover bg-slate-200 group-hover:scale-105 transition-transform duration-700">
                                    {% else %}
                                        <img src="{{ asset('images/avatar-placeholder.jpg') }}" alt="{{ speaker.name }}" width="400" height="400" loading="{{ loop.index <= 4 ? 'eager' : 'lazy' }}"
                                             class="w-full h-80 object-cover bg-slate-200 group-hover:scale-105 transition-transform duration-700">
                                    {% endif %}
                                    <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent"></div>
                                    <div class="absolute bottom-4 left-6 right-6">
                                        <h3 class="text-xl font-bold text-white mb-1">{{ speaker.name }}</h3>
                                        <p class="text-secondary text-sm font-semibold">{{ speaker.institution }}</p>
                                    </div>
                                </div>
                                <div class="p-6">
                                    <p class="text-slate-600 text-sm mb-6 line-clamp-3">{{ speaker.shortBio }}</p>
                                </div>
                            </div>
                            
                            <div class="p-6 pt-0">
                                <div class="flex items-center justify-between border-t border-slate-100 pt-4">
                                    <a href="{{ path('app_palestrante_detalhe', {'id': speaker.id}) }}"
                                        class="text-sm font-bold text-primary hover:text-secondary flex items-center gap-1 transition-colors">
                                        Full Profile <span class="material-symbols-outlined text-sm">arrow_forward</span>
                                    </a>
                                    <div class="flex gap-2">
                                        {% if speaker.scholarUrl %}
                                            <a href="{{ speaker.scholarUrl }}" target="_blank" title="Scholar Profile" class="text-slate-400 hover:text-primary">
                                                <span class="material-symbols-outlined text-lg">school</span>
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>

                                {% if speaker.activities is not empty %}
                                    <div class="mt-4 bg-slate-50 p-3 rounded-lg border border-slate-100">
                                        <span class="text-xs text-slate-500 block mb-1">Engaged in:</span>
                                        {% for act in speaker.activities %}
                                            <a href="{{ path('app_programa', {'day': act.eventDay.id}) }}" class="text-xs font-bold text-secondary hover:underline truncate block">
                                                {{ act.title }} ({{ act.startTime ? act.startTime|date('D, H:i A') : '' }})
                                            </a>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-20 bg-white rounded-xl card-shadow">
                    <span class="material-symbols-outlined text-5xl text-slate-300 mb-4">groups</span>
                    <h3 class="text-xl font-bold text-slate-700">No speakers registered yet.</h3>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}

{% block stylesheets %}
    {# Preload the LCP Banner Image #}
    {% if event_config and event_config.heroImage and event_config.heroImage.imageName %}
        <link rel="preload" as="image" href="{{ ('uploads/' ~ event_config.heroImage.imageName)|imagine_filter('banner_hero') }}" />
    {% else %}
        <link rel="preload" as="image" href="{{ asset('images/hero-bg.jpg') }}" />
    {% endif %}
{% endblock %}
