{% extends 'pub/base.html.twig' %}

{% block body %}
    <section class="bg-slate-900 text-white py-20 relative overflow-hidden border-b-8 border-secondary">
        {% if event_config and event_config.heroImage and event_config.heroImage.imageName %}
            <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('{{ ('uploads/' ~ event_config.heroImage.imageName)|imagine_filter('banner_hero') }}'); background-color: #004040;"></div>
        {% else %}
            <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('{{ asset('fundecitrus-congresso-layout/assets/images/hero-bg.jpg') }}'); background-color: #004040;"></div>
        {% endif %}
        <div class="container mx-auto px-6 text-center relative z-10">
            <span class="material-symbols-outlined text-secondary text-5xl mb-4">confirmation_number</span>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Registration</h1>
            <p class="text-secondary text-lg max-w-2xl mx-auto">Secure your spot at the world's most significant HLB conference. Review our distinct categories and deadlines below.</p>
        </div>
    </section>

    <!-- Pricing Tables -->
    <section class="py-24 bg-white text-slate-800">
        <div class="container mx-auto px-6">
            
            <!-- Structural Details and Deadlines -->
            <div class="mb-16" data-aos="fade-up">
                <h2 class="text-3xl font-bold text-primary mb-8 text-center">Registration Batches & Deadlines</h2>
                
                {% if batches is not empty %}
                    <div class="overflow-x-auto card-shadow rounded-xl max-w-4xl mx-auto" data-aos="fade-up" data-aos-delay="200">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-primary text-white">
                                    <th class="py-4 px-6 font-bold">Registration Batch</th>
                                    <th class="py-4 px-6 font-bold">Start Date</th>
                                    <th class="py-4 px-6 font-bold">End Date / Deadline</th>
                                    <th class="py-4 px-6 font-bold">Value / Price</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-slate-100">
                                {% for batch in batches %}
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="py-4 px-6 font-semibold text-primary">{{ batch.name }}</td>
                                        <td class="py-4 px-6">{{ batch.startDate ? batch.startDate|date('M d, Y') : '' }}</td>
                                        <td class="py-4 px-6">{{ batch.endDate ? batch.endDate|date('M d, Y') : '' }}</td>
                                        <td class="py-4 px-6 font-bold text-secondary">$ {{ batch.price }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="text-center text-slate-500">No registration batches defined yet.</p>
                {% endif %}
            </div>

            <!-- Pre-Registration / Form Callout -->
            <div class="bg-slate-50 rounded-2xl p-10 md:p-16 text-center card-shadow border border-slate-100 mb-24 max-w-4xl mx-auto hover-effect" data-aos="fade-up">
                <h3 class="text-2xl font-bold text-primary mb-4">Ready to Register?</h3>
                <p class="text-slate-600 mb-8 max-w-2xl mx-auto">The process uses a robust gateway accepting Credit Cards, Boletos, PIX. International attendees possess a streamlined portal restricted to Credit Card + Passport validation.</p>
                <a href="#" onclick="alert('Registration forms are handled externally. Link will be available soon.'); return false;" 
                   class="inline-block bg-secondary text-primary font-bold text-lg px-10 py-4 rounded shadow-lg hover-effect">
                    Proceed to Form
                </a>
            </div>

            <!-- Documents and Receipts Logistics -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-24 max-w-4xl mx-auto">
                <div class="bg-white p-8 rounded-2xl border border-slate-100 card-shadow hover-effect" data-aos="fade-right">
                    <h3 class="text-2xl font-bold text-primary mb-4 flex items-center gap-3">
                        <span class="material-symbols-outlined text-secondary">request_quote</span>
                        Receipts & Invoices
                    </h3>
                    <p class="text-slate-600 mb-4">Official invoices (Notas Fiscais) will be issued following strict regulations of the Ribeirão Preto Municipal Government.</p>
                    <p class="text-slate-600">Please assure all billing information is immaculate during checkout, as subsequent alterations to corporate names may not be permitted.</p>
                </div>
                <div class="bg-white p-8 rounded-2xl border border-slate-100 card-shadow hover-effect" data-aos="fade-left">
                    <h3 class="text-2xl font-bold text-primary mb-4 flex items-center gap-3">
                        <span class="material-symbols-outlined text-secondary">workspace_premium</span>
                        Certificates
                    </h3>
                    <p class="text-slate-600">Certificates of attendance will be available dynamically in the restricted user area precisely 48 hours after the conclusion of the event.</p>
                </div>
            </div>

            <!-- FAQ Section -->
            {% if faq_items is not empty %}
                <div>
                    <h3 class="text-3xl font-bold text-primary mb-8 text-center">Registration FAQ & Policies</h3>
                    <div class="max-w-3xl mx-auto space-y-4" data-aos="fade-up">
                        {% for faq in faq_items %}
                            <details class="group bg-slate-50 rounded-lg border border-slate-200 open:bg-white open:ring-1 open:ring-slate-300 open:shadow-sm">
                                <summary class="flex justify-between items-center font-medium cursor-pointer list-none p-5 text-slate-800">
                                    <span class="font-bold">{{ faq.question }}</span>
                                    <span class="transition group-open:rotate-180 material-symbols-outlined text-slate-400">expand_more</span>
                                </summary>
                                <div class="text-slate-600 p-5 pt-0 border-t border-slate-100 mt-2">
                                    <p>{{ faq.answer }}</p>
                                </div>
                            </details>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

        </div>
    </section>
{% endblock %}

{% block stylesheets %}
    {# Preload the LCP Banner Image #}
    {% if event_config and event_config.heroImage and event_config.heroImage.imageName %}
        <link rel="preload" as="image" href="{{ ('uploads/' ~ event_config.heroImage.imageName)|imagine_filter('banner_hero') }}" />
    {% else %}
        <link rel="preload" as="image" href="{{ asset('fundecitrus-congresso-layout/assets/images/hero-bg.jpg') }}" />
    {% endif %}
{% endblock %}
