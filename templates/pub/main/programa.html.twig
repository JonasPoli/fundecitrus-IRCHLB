{% extends 'pub/base.html.twig' %}

{% block body %}
    <section class="bg-slate-900 text-white py-16 relative overflow-hidden border-b-8 border-secondary">
        {% if event_config and event_config.heroImage and event_config.heroImage.imageName %}
            <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('{{ ('uploads/' ~ event_config.heroImage.imageName)|imagine_filter('banner_hero') }}'); background-color: #004040;"></div>
        {% else %}
            <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('{{ asset('fundecitrus-congresso-layout/assets/images/hero-bg.jpg') }}'); background-color: #004040;"></div>
        {% endif %}
        <div class="container mx-auto px-6 text-center relative z-10">
            <span class="material-symbols-outlined text-secondary text-5xl mb-4">calendar_month</span>
            <h1 class="text-4xl md:text-5xl font-bold mb-4">Event Schedule & Program</h1>
            <p class="text-secondary text-lg max-w-2xl mx-auto">A meticulous timeline outlining plenary sessions, keynotes, and technical symposiums.</p>
        </div>
    </section>

    <!-- Global Calendar View (Tabs) -->
    {% if days is not empty %}
        <section class="py-12 bg-white sticky top-[72px] z-40 border-b border-slate-200 shadow-sm">
            <div class="container mx-auto px-6">
                <!-- Relative wrapper for horizontal scroll indicators -->
                <div class="relative w-full overflow-hidden" id="days-nav-wrapper">
                    <!-- Left indicator: faded gradient + chevron. Hidden initially. -->
                    <div id="scroll-left-indicator" class="absolute left-0 top-0 bottom-0 w-16 bg-gradient-to-r from-white via-white/80 to-transparent pointer-events-none z-10 flex items-center justify-start opacity-0 transition-opacity duration-300">
                        <span class="material-symbols-outlined text-primary font-extrabold ml-1 bg-white/90 p-1.5 rounded-full shadow-md">chevron_left</span>
                    </div>

                    <!-- Scrollable container -->
                    <div id="days-nav-container" class="flex overflow-x-auto hide-scroll-bar gap-4 p-2 justify-start md:justify-center scroll-smooth scrollbar-none" data-aos="fade-down">
                        {% for day in days %}
                            {% if active_day and active_day.id == day.id %}
                                <a href="{{ path('app_programa', {'day': day.id}) }}" class="bg-primary text-white px-8 py-3 rounded-full font-bold whitespace-nowrap card-shadow">
                                    {{ day.title }} ({{ day.date ? day.date|date('M d, Y') : '' }})
                                </a>
                            {% else %}
                                <a href="{{ path('app_programa', {'day': day.id}) }}" class="bg-slate-100 text-slate-600 hover:bg-slate-200 px-8 py-3 rounded-full font-bold whitespace-nowrap transition-colors">
                                    {{ day.title }} ({{ day.date ? day.date|date('M d, Y') : '' }})
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <!-- Right indicator: faded gradient + chevron. Visible initially (pulsating). -->
                    <div id="scroll-right-indicator" class="absolute right-0 top-0 bottom-0 w-16 bg-gradient-to-l from-white via-white/80 to-transparent pointer-events-none z-10 flex items-center justify-end opacity-0 transition-opacity duration-300">
                        <span class="material-symbols-outlined text-primary font-extrabold mr-1 bg-white/90 p-1.5 rounded-full shadow-md animate-pulse">chevron_right</span>
                    </div>
                </div>
            </div>
        </section>

        {# Scroll Indicators Controller Script #}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const container = document.getElementById('days-nav-container');
                const leftInd = document.getElementById('scroll-left-indicator');
                const rightInd = document.getElementById('scroll-right-indicator');

                if (container && leftInd && rightInd) {
                    const updateIndicators = () => {
                        const scrollLeft = container.scrollLeft;
                        const maxScroll = container.scrollWidth - container.clientWidth;

                        // Left indicator visibility
                        if (scrollLeft > 10) {
                            leftInd.classList.remove('opacity-0');
                            leftInd.classList.add('opacity-100');
                        } else {
                            leftInd.classList.remove('opacity-100');
                            leftInd.classList.add('opacity-0');
                        }

                        // Right indicator visibility (only if there is actually content to scroll)
                        if (maxScroll > 10 && (maxScroll - scrollLeft > 10)) {
                            rightInd.classList.remove('opacity-0');
                            rightInd.classList.add('opacity-100');
                        } else {
                            rightInd.classList.remove('opacity-100');
                            rightInd.classList.add('opacity-0');
                        }
                    };

                    container.addEventListener('scroll', updateIndicators);
                    
                    // Initial check and check after load
                    updateIndicators();
                    window.addEventListener('resize', updateIndicators);
                    
                    // Scroll to the active button on load so it's visible
                    const activeBtn = container.querySelector('.bg-primary');
                    if (activeBtn) {
                        const containerWidth = container.clientWidth;
                        const btnLeft = activeBtn.offsetLeft;
                        const btnWidth = activeBtn.clientWidth;
                        container.scrollLeft = btnLeft - (containerWidth / 2) + (btnWidth / 2);
                    }
                    
                    // Recheck position after scrolling active button into view
                    setTimeout(updateIndicators, 100);
                }
            });
        </script>
    {% endif %}

    <!-- Agenda Body -->
    <section class="py-16 bg-slate-50 min-h-screen">
        <div class="container mx-auto px-6 max-w-5xl">
            
            {% if activities is not empty %}
                <div class="space-y-6">
                    {% for activity in activities %}
                        {% set isBreak = activity.type in ['Coffee Break', 'Lunch Break', 'Interval', 'Networking Lunch Break'] %}
                        
                        <div class="flex flex-col md:flex-row bg-white rounded-xl overflow-hidden card-shadow border-l-8 {% if isBreak %}border-slate-400{% else %}border-primary{% endif %} hover-effect" data-aos="fade-up" data-aos-delay="{{ (loop.index0 % 5) * 200 }}">
                            <div class="bg-slate-100 md:w-48 p-6 flex flex-col justify-center items-center shrink-0 border-b md:border-b-0 md:border-r border-slate-200">
                                <span class="text-xl font-bold text-primary">{{ activity.startTime ? activity.startTime|date('H:i A') : '' }}</span>
                                <span class="text-sm text-slate-500">{{ activity.endTime ? activity.endTime|date('H:i A') : '' }}</span>
                            </div>
                            <div class="p-6 md:p-8 flex-grow flex flex-col justify-between">
                                <div>
                                    <div class="flex flex-wrap gap-2 items-center mb-2">
                                        <span class="bg-primary/10 text-primary text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                                            {{ activity.type }}
                                        </span>
                                    </div>
                                    <h3 class="text-2xl font-bold text-primary mb-2">{{ activity.title }}</h3>
                                    
                                    {% if activity.description %}
                                        <p class="text-slate-600 text-sm mb-4">{{ activity.description }}</p>
                                    {% endif %}
                                </div>
                                
                                <div class="flex items-center gap-2 text-slate-500 text-sm mb-4">
                                    <span class="material-symbols-outlined text-base">location_on</span>
                                    <span>{{ activity.room.name ?? '' }}</span>
                                </div>
                                
                                {% if activity.speakers is not empty and not isBreak %}
                                    <div class="mt-4 pt-4 border-t border-slate-100 flex items-center gap-4">
                                        <div class="flex -space-x-4">
                                            {% for speaker in activity.speakers %}
                                                {% if speaker.image and speaker.image.imageName %}
                                                    <img class="w-10 h-10 rounded-full border-2 border-white object-cover bg-slate-200" 
                                                         src="{{ ('uploads/' ~ speaker.image.imageName)|imagine_filter('avatar_mini') }}" alt="{{ speaker.name }}" width="40" height="40" loading="lazy">
                                                {% else %}
                                                    <img class="w-10 h-10 rounded-full border-2 border-white object-cover bg-slate-200" 
                                                         src="{{ asset('fundecitrus-congresso-layout/assets/images/avatar-placeholder.jpg') }}" alt="{{ speaker.name }}" width="40" height="40" loading="lazy">
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                        <div>
                                            <span class="text-xs text-slate-400 block">Speakers:</span>
                                            {% for speaker in activity.speakers %}
                                                <a href="{{ path('app_palestrante_detalhe', {'id': speaker.id}) }}" class="text-sm font-bold text-secondary hover:underline mr-2">
                                                    {{ speaker.name }}{{ not loop.last ? ',' : '' }}
                                                </a>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-20 bg-white rounded-xl card-shadow">
                    <span class="material-symbols-outlined text-5xl text-slate-300 mb-4">calendar_today</span>
                    <h3 class="text-xl font-bold text-slate-700">No activities scheduled for this day yet.</h3>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}

{% block stylesheets %}
    {# Preload the LCP Banner Image #}
    {% if event_config and event_config.heroImage and event_config.heroImage.imageName %}
        <link rel="preload" as="image" href="{{ ('uploads/' ~ event_config.heroImage.imageName)|imagine_filter('banner_hero') }}" />
    {% else %}
        <link rel="preload" as="image" href="{{ asset('fundecitrus-congresso-layout/assets/images/hero-bg.jpg') }}" />
    {% endif %}
{% endblock %}
