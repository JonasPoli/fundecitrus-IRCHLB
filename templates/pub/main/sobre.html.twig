                                <p class="text-slate-300">Access unreleased papers, frontier research, and data from international groups working directly on HLB and citrus virology.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="material-symbols-outlined text-secondary align-top">diversity_3</span>
                            <div>
                                <h4 class="font-bold text-xl">Premium Networking</h4>
                                <p class="text-slate-300">Interact with regulators, industry heavyweights, and global researchers during our targeted coffee breaks and social events.</p>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="md:w-1/2" data-aos="fade-left">
                    <div class="relative rounded-2xl overflow-hidden card-shadow">
                        <img src="{{ asset('images/conference-room.jpg') }}" alt="Conference Room" width="940" height="627" loading="lazy"
                            class="w-full h-auto object-cover bg-slate-200">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline Switching Script -->
    <script>
        function switchTimeline(type) {
            const btnIrchlb = document.getElementById('tab-irchlb');
            const btnIocv = document.getElementById('tab-iocv');
            const tlIrchlb = document.getElementById('timeline-irchlb');
            const tlIocv = document.getElementById('timeline-iocv');

            if (type === 'irchlb') {
                btnIrchlb.className = "px-6 py-3 rounded-lg text-sm font-bold transition-all duration-200 bg-primary text-white shadow-sm";
                btnIocv.className = "px-6 py-3 rounded-lg text-sm font-bold transition-all duration-200 text-slate-600 hover:text-primary";
                
                tlIocv.classList.add('opacity-0');
                setTimeout(() => {
                    tlIocv.classList.add('hidden');
                    tlIrchlb.classList.remove('hidden');
                    setTimeout(() => {
                        tlIrchlb.classList.remove('opacity-0');
                        if (window.AOS) window.AOS.refresh();
                    }, 50);
                }, 200);
            } else {
                btnIocv.className = "px-6 py-3 rounded-lg text-sm font-bold transition-all duration-200 bg-primary text-white shadow-sm";
                btnIrchlb.className = "px-6 py-3 rounded-lg text-sm font-bold transition-all duration-200 text-slate-600 hover:text-primary";
                
                tlIrchlb.classList.add('opacity-0');
                setTimeout(() => {
                    tlIrchlb.classList.add('hidden');
                    tlIocv.classList.remove('hidden');
                    setTimeout(() => {
                        tlIocv.classList.remove('opacity-0');
                        if (window.AOS) window.AOS.refresh();
                    }, 50);
                }, 200);
            }
        }
    </script>
