            <div class="container mx-auto px-6">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4" data-aos="fade-up">Organizing Committee &amp; Scientific Committee</h2>
                    <p class="text-secondary text-lg font-bold italic" data-aos="fade-up" data-aos-delay="100">(Subject to confirmation)</p>
                </div>

                {% set countries = [
                    'Brazil', 'Florida, USA', 'Texas, USA', 'California, USA', 'USDA APHIS',
                    'China', 'South Africa', 'Argentina', 'Costa Rica', 'Spain', 'Australia', 'Mexico', 'Scientific Advisor'
                ] %}

                {% for country in countries %}
                    {% set country_members = [] %}
                    {% for member in committee_members %}
                        {% if member.groupType == country %}
                            {% set country_members = country_members|merge([member]) %}
                        {% endif %}
                    {% endfor %}

                    {% if country_members is not empty %}
                        <div class="mb-16" data-aos="fade-up">
                            <!-- Country Header -->
                            <div class="flex items-center gap-4 mb-8">
                                <h3 class="text-2xl font-bold text-primary border-l-4 border-secondary pl-4">{{ country }}</h3>
                                <div class="flex-grow h-px bg-slate-200"></div>
                            </div>

                            <!-- Members Grid -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
                                {% for member in country_members %}
                                    <div class="bg-white rounded-xl card-shadow border border-slate-100 p-6 text-center hover-effect flex flex-col justify-between h-full">
                                        <div>
                                            <div class="relative w-28 h-28 mx-auto mb-6">
                                                {% if member.image and member.image.imageName %}
                                                    <img src="{{ ('uploads/' ~ member.image.imageName)|imagine_filter('avatar') }}" alt="{{ member.name }}" width="112" height="112" loading="lazy"
                                                        class="w-full h-full rounded-full object-cover bg-slate-200 border-2 border-slate-100">
                                                {% else %}
                                                    {% if member.name in ['MaryLou Polek', 'Carolina Ramirez'] %}
                                                        <img src="{{ asset('images/avatar-placeholder-2.jpg') }}" alt="{{ member.name }}" width="112" height="112" loading="lazy"
                                                            class="w-full h-full rounded-full object-cover bg-slate-200 border-2 border-slate-100">
                                                    {% else %}
                                                        <img src="{{ asset('images/avatar-placeholder.jpg') }}" alt="{{ member.name }}" width="112" height="112" loading="lazy"
                                                            class="w-full h-full rounded-full object-cover bg-slate-200 border-2 border-slate-100">
                                                    {% endif %}
                                                {% endif %}
                                                {% if member.role == 'Chair' %}
                                                    <span class="absolute bottom-0 right-0 bg-secondary text-primary font-bold text-[10px] px-2 py-0.5 rounded-full uppercase shadow">Chair</span>
                                                {% endif %}
                                            </div>

                                            <h4 class="text-lg font-bold text-primary mb-1">
                                                {{ member.name }}
                                                {% if member.role == 'Chair' %}
                                                    <span class="text-secondary text-xs block lg:inline-block font-semibold">(Chair)</span>
                                                {% endif %}
                                            </h4>
                                            
                                            <p class="text-xs font-semibold text-secondary mb-2">
                                                {% if member.role != 'Chair' and member.role != 'Member' %}
                                                    {{ member.role }}
                                                {% endif %}
                                            </p>
                                            
                                            <p class="text-xs text-slate-500 mb-3 leading-relaxed font-semibold">{{ member.institution }}</p>
                                            <p class="text-xs text-slate-400 leading-relaxed">{{ member.bio }}</p>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </section>
    {% endif %}

    <!-- Benefits (Why Participate) -->
    <section class="py-24 bg-primary text-white">
        <div class="container mx-auto px-6">
            <div class="flex flex-col md:flex-row gap-16 items-center">
                <div class="md:w-1/2" data-aos="fade-right">
                    <h2 class="text-4xl font-bold mb-6">Why You Should Attend</h2>
                    <p class="text-lg text-slate-300 mb-8 leading-relaxed">Attending the joint conferences represents an imperative investment for professionals and academics within the agricultural sciences.</p>

                    <ul class="space-y-4">
                        <li class="flex items-start gap-4">
                            <span class="material-symbols-outlined text-secondary align-top">tips_and_updates</span>
                            <div>
