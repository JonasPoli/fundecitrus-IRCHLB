{% extends 'pub/base.html.twig' %}

{% block body %}
    <!-- Page Header -->
    <section class="bg-slate-900 text-white py-20 relative overflow-hidden border-b-8 border-secondary">
        {% if event_config and event_config.heroImage and event_config.heroImage.imageName %}
            <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('{{ ('uploads/' ~ event_config.heroImage.imageName)|imagine_filter('banner_hero') }}'); background-color: #004040;"></div>
        {% else %}
            <div class="absolute inset-0 opacity-30 bg-cover bg-center" style="background-image: url('{{ asset('fundecitrus-congresso-layout/assets/images/hero-bg.jpg') }}'); background-color: #004040;"></div>
        {% endif %}
        <div class="container mx-auto px-6 text-center relative z-10">
            <span class="material-symbols-outlined text-secondary text-5xl mb-4">groups</span>
            <h1 class="text-4xl md:text-5xl font-bold mb-4">About the Conference</h1>
            <p class="text-secondary text-lg max-w-2xl mx-auto">Discover the foundation, history, and the dedicated team behind the global assembly on Huanglongbing.</p>
        </div>
    </section>

    <!-- Mission & Objectives -->
    <section class="py-24 bg-white">
        <div class="container mx-auto px-6 max-w-4xl" data-aos="fade-up">
            <div class="text-center mb-12">
                <span class="material-symbols-outlined text-secondary text-5xl mb-4">flag</span>
                <h2 class="text-3xl font-bold text-primary mb-6">Mission & Objectives</h2>
            </div>
            <div class="prose prose-lg text-slate-700 mx-auto">
                <p>The VIII International Research Conference on Huanglongbing represents the most vital academic and operational convergence point for discussing, mapping, and confronting the HLB citrus disease. Our root conceptual objective is to foster deep collaboration across borders.</p>
                <p>We aim to aggregate scientists, industry leaders, and agricultural stewards to formulate resilient solutions against the devastation caused by HLB, paving the path to sustainable practices over the next decade.</p>
            </div>
        </div>
    </section>

    <!-- History & Past Editions -->
    <section class="py-24 bg-slate-50 border-t border-b border-slate-200 overflow-hidden">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="text-center mb-16" data-aos="fade-up">
                <span class="material-symbols-outlined text-secondary text-5xl mb-4">history</span>
                <h2 class="text-3xl font-bold text-primary mb-4">History & Past Editions</h2>
                <p class="text-slate-500 max-w-2xl mx-auto">Tracing the legacy and growth of the global convergence against Huanglongbing (HLB) since its inception.</p>
            </div>

            <!-- Timeline Container -->
            <div class="relative wrap overflow-hidden p-2 lg:p-10 h-full">
                <!-- Vertical Line -->
                <div class="absolute border-l-2 border-slate-200 h-full left-5 lg:left-1/2 -translate-x-1/2"></div>

                <!-- Timeline Item 7 (Right) -->
                <div class="mb-12 flex flex-row lg:flex-row items-center justify-between w-full" data-aos="fade-left">
                    <div class="order-1 lg:w-5/12 w-0 hidden lg:block"></div>
                    <div class="z-20 flex items-center order-1 bg-secondary shadow-xl w-10 h-10 rounded-full justify-center left-5 lg:left-1/2 -translate-x-1/2 absolute lg:relative">
                        <span class="text-primary font-extrabold text-sm">7</span>
                    </div>
                    <div class="order-1 bg-white rounded-xl shadow-md border border-slate-100 lg:w-5/12 w-[calc(100%-3rem)] ml-12 lg:ml-0 p-6 hover-effect">
                        <span class="text-xs font-bold text-secondary uppercase tracking-wider mb-1 block">IRCHLB VII — 2024</span>
                        <h3 class="font-bold text-primary text-xl mb-2">Riverside, California</h3>
                        <p class="text-sm text-slate-600">Themed "Transitioning Research to Field Reality," this edition assembled over 450 scientists to debate breakthrough genomic tools and antimicrobial orchard therapies.</p>
                    </div>
                </div>

                <!-- Timeline Item 6 (Left) -->
                <div class="mb-12 flex flex-row lg:flex-row-reverse items-center justify-between w-full" data-aos="fade-right">
                    <div class="order-1 lg:w-5/12 w-0 hidden lg:block"></div>
                    <div class="z-20 flex items-center order-1 bg-primary shadow-xl w-10 h-10 rounded-full justify-center left-5 lg:left-1/2 -translate-x-1/2 absolute lg:relative">
                        <span class="text-secondary font-bold text-sm">6</span>
                    </div>
                    <div class="order-1 bg-white rounded-xl shadow-md border border-slate-100 lg:w-5/12 w-[calc(100%-3rem)] ml-12 lg:ml-0 p-6 hover-effect">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1 block">IRCHLB VI — 2019</span>
                        <h3 class="font-bold text-primary text-xl mb-2">Riverside, California</h3>
                        <p class="text-sm text-slate-600">Focused heavily on psyllid vector population dynamics, regional monitoring networks, and chemical suppression methods under high disease pressure.</p>
                    </div>
                </div>

                <!-- Timeline Item 5 (Right) -->
                <div class="mb-12 flex flex-row lg:flex-row items-center justify-between w-full" data-aos="fade-left">
                    <div class="order-1 lg:w-5/12 w-0 hidden lg:block"></div>
                    <div class="z-20 flex items-center order-1 bg-primary shadow-xl w-10 h-10 rounded-full justify-center left-5 lg:left-1/2 -translate-x-1/2 absolute lg:relative">
                        <span class="text-secondary font-bold text-sm">5</span>
                    </div>
                    <div class="order-1 bg-white rounded-xl shadow-md border border-slate-100 lg:w-5/12 w-[calc(100%-3rem)] ml-12 lg:ml-0 p-6 hover-effect">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1 block">IRCHLB V — 2017</span>
                        <h3 class="font-bold text-primary text-xl mb-2">Orlando, Florida</h3>
                        <p class="text-sm text-slate-600">Centered on genomic sequencing of *Candidatus Liberibacter* species and early-stage trials of tolerant transgenic citrus rootstocks.</p>
                    </div>
                </div>

                <!-- Timeline Item 4 (Left) -->
                <div class="mb-12 flex flex-row lg:flex-row-reverse items-center justify-between w-full" data-aos="fade-right">
                    <div class="order-1 lg:w-5/12 w-0 hidden lg:block"></div>
                    <div class="z-20 flex items-center order-1 bg-primary shadow-xl w-10 h-10 rounded-full justify-center left-5 lg:left-1/2 -translate-x-1/2 absolute lg:relative">
                        <span class="text-secondary font-bold text-sm">4</span>
                    </div>
                    <div class="order-1 bg-white rounded-xl shadow-md border border-slate-100 lg:w-5/12 w-[calc(100%-3rem)] ml-12 lg:ml-0 p-6 hover-effect">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1 block">IRCHLB IV — 2015</span>
                        <h3 class="font-bold text-primary text-xl mb-2">Orlando, Florida</h3>
                        <p class="text-sm text-slate-600">Highlighted biological vector control via *Tamarixia radiata* releases and targeted nutritional spray programs to extend grove productivity.</p>
                    </div>
                </div>

                <!-- Timeline Item 3 (Right) -->
                <div class="mb-12 flex flex-row lg:flex-row items-center justify-between w-full" data-aos="fade-left">
                    <div class="order-1 lg:w-5/12 w-0 hidden lg:block"></div>
                    <div class="z-20 flex items-center order-1 bg-primary shadow-xl w-10 h-10 rounded-full justify-center left-5 lg:left-1/2 -translate-x-1/2 absolute lg:relative">
                        <span class="text-secondary font-bold text-sm">3</span>
                    </div>
                    <div class="order-1 bg-white rounded-xl shadow-md border border-slate-100 lg:w-5/12 w-[calc(100%-3rem)] ml-12 lg:ml-0 p-6 hover-effect">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1 block">IRCHLB III — 2013</span>
                        <h3 class="font-bold text-primary text-xl mb-2">Orlando, Florida</h3>
                        <p class="text-sm text-slate-600">Addressed grove epidemiology, vector feeding mechanics, and international quarantine standards for material exchanges.</p>
                    </div>
                </div>

                <!-- Timeline Item 2 (Left) -->
                <div class="mb-12 flex flex-row lg:flex-row-reverse items-center justify-between w-full" data-aos="fade-right">
                    <div class="order-1 lg:w-5/12 w-0 hidden lg:block"></div>
                    <div class="z-20 flex items-center order-1 bg-primary shadow-xl w-10 h-10 rounded-full justify-center left-5 lg:left-1/2 -translate-x-1/2 absolute lg:relative">
                        <span class="text-secondary font-bold text-sm">2</span>
                    </div>
                    <div class="order-1 bg-white rounded-xl shadow-md border border-slate-100 lg:w-5/12 w-[calc(100%-3rem)] ml-12 lg:ml-0 p-6 hover-effect">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1 block">IRCHLB II — 2011</span>
                        <h3 class="font-bold text-primary text-xl mb-2">Orlando, Florida</h3>
                        <p class="text-sm text-slate-600">Established cooperative research programs between the USA and Brazil to standardize data collections and vector mapping criteria.</p>
                    </div>
                </div>

                <!-- Timeline Item 1 (Right) -->
                <div class="flex flex-row lg:flex-row items-center justify-between w-full" data-aos="fade-left">
                    <div class="order-1 lg:w-5/12 w-0 hidden lg:block"></div>
                    <div class="z-20 flex items-center order-1 bg-primary shadow-xl w-10 h-10 rounded-full justify-center left-5 lg:left-1/2 -translate-x-1/2 absolute lg:relative">
                        <span class="text-secondary font-bold text-sm">1</span>
                    </div>
                    <div class="order-1 bg-white rounded-xl shadow-md border border-slate-100 lg:w-5/12 w-[calc(100%-3rem)] ml-12 lg:ml-0 p-6 hover-effect">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1 block">IRCHLB I — 2008</span>
                        <h3 class="font-bold text-primary text-xl mb-2">Orlando, Florida</h3>
                        <p class="text-sm text-slate-600">The inaugural assembly defining the threat global parameters, establishing early joint budgets, and drawing up a global collaborative roadmap.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Organizing Committee -->
    {% if committee_members is not empty %}
        <section class="py-24 bg-white border-t border-b border-slate-100">
            <div class="container mx-auto px-6">
                <h2 class="text-3xl font-bold text-primary mb-4 text-center" data-aos="fade-up">Organizing Committee</h2>
                <p class="text-center text-slate-500 mb-16 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">Meet the specialists and institutional leaders dedicated to bringing forth a world-class conference.</p>

                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
                    {% for member in committee_members %}
                        <div class="bg-white rounded-xl card-shadow border border-slate-100 p-8 text-center hover-effect" data-aos="fade-up" data-aos-delay="{{ (loop.index0 % 4) * 100 }}">
                            {% if member.image and member.image.imageName %}
                                <img src="{{ ('uploads/' ~ member.image.imageName)|imagine_filter('avatar') }}" alt="{{ member.name }}" width="128" height="128" loading="lazy"
                                    class="w-32 h-32 rounded-full mx-auto object-cover mb-6 bg-slate-200">
                            {% else %}
                                <img src="{{ asset('fundecitrus-congresso-layout/assets/images/avatar-placeholder.jpg') }}" alt="{{ member.name }}" width="128" height="128" loading="lazy"
                                    class="w-32 h-32 rounded-full mx-auto object-cover mb-6 bg-slate-200">
                            {% endif %}
                            
                            <h3 class="text-xl font-bold text-primary">{{ member.name }}</h3>
                            <p class="text-sm font-semibold text-secondary mb-1">{{ member.role }}</p>
                            <p class="text-xs text-slate-400 mb-3">{{ member.institution }}</p>
                            <p class="text-sm text-slate-500 line-clamp-3">{{ member.bio }}</p>
                            
                            <div class="flex justify-center gap-3 mt-4">
                                {% if member.linkedinUrl %}
                                    <a href="{{ member.linkedinUrl }}" target="_blank" class="text-slate-400 hover:text-primary transition-colors">
                                        <i class="fa-brands fa-linkedin text-lg"></i>
                                    </a>
                                {% endif %}
                                {% if member.academicLink %}
                                    <a href="{{ member.academicLink }}" target="_blank" class="text-slate-400 hover:text-primary transition-colors">
                                        <span class="material-symbols-outlined text-lg">school</span>
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    <!-- Benefits (Why Participate) -->
    <section class="py-24 bg-primary text-white">
        <div class="container mx-auto px-6">
            <div class="flex flex-col md:flex-row gap-16 items-center">
                <div class="md:w-1/2" data-aos="fade-right">
                    <h2 class="text-4xl font-bold mb-6">Why You Should Attend</h2>
                    <p class="text-lg text-slate-300 mb-8 leading-relaxed">Attending the IRCHLB represents an imperative investment for professionals and academics within the agricultural sciences.</p>

                    <ul class="space-y-4">
                        <li class="flex items-start gap-4">
                            <span class="material-symbols-outlined text-secondary align-top">tips_and_updates</span>
                            <div>
                                <h4 class="font-bold text-xl">Knowledge Acquisition</h4>
                                <p class="text-slate-300">Access unreleased papers, frontier research, and data from international groups working directly on the HLB challenge.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="material-symbols-outlined text-secondary align-top">diversity_3</span>
                            <div>
                                <h4 class="font-bold text-xl">Premium Networking</h4>
                                <p class="text-slate-300">Interact with regulators, industry heavyweights, and global researchers during our targeted coffee breaks and social events.</p>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="md:w-1/2" data-aos="fade-left">
                    <div class="relative rounded-2xl overflow-hidden card-shadow">
                        <img src="{{ asset('fundecitrus-congresso-layout/assets/images/conference-room.jpg') }}" alt="Conference Room" width="940" height="627" loading="lazy"
                            class="w-full h-auto object-cover bg-slate-200">
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block stylesheets %}
    {# Preload the LCP Banner Image #}
    {% if event_config and event_config.heroImage and event_config.heroImage.imageName %}
        <link rel="preload" as="image" href="{{ ('uploads/' ~ event_config.heroImage.imageName)|imagine_filter('banner_hero') }}" />
    {% else %}
        <link rel="preload" as="image" href="{{ asset('fundecitrus-congresso-layout/assets/images/hero-bg.jpg') }}" />
    {% endif %}
{% endblock %}
