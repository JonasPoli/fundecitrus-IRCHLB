<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">

    {# SEO Meta Tags #}
    <title>{% block title %}{{ event_config.title ?? 'VIII International Research Conference on Huanglongbing (IRCHLB)' }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ event_config.heroDescription ?? '' }}{% endblock %}">

    {# Webfonts & Icons #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

    {# TailwindCSS CDN #}
    <script src="https://cdn.tailwindcss.com"></script>
    <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#014040',
                        secondary: '#B9D04A',
                        slate: {
                            50: '#f8fafc',
                            100: '#f1f5f9',
                            200: '#e2e8f0',
                            900: '#0f172a',
                        }
                    },
                    fontFamily: {
                        sans: ['Montserrat', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    {# Custom CSS Stylesheet #}
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="bg-slate-50 text-slate-800 flex flex-col min-h-screen">

    {# Skip to main content link for keyboard/screen reader users #}
    <a href="#main-content"
       class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-lg focus:shadow-lg">
        Skip to main content
    </a>

    {# Dynamic Header #}
    <header class="bg-primary text-white shadow-md sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a href="{{ path('app_home') }}" class="flex items-center">
                <img src="{{ asset('fundecitrus-congresso-layout/assets/images/logo.png') }}" alt="IRCHLB 2027" class="h-12 w-auto">
            </a>
            
            {% set route = app.request.attributes.get('_route') %}
            <nav class="hidden lg:flex space-x-6 text-sm font-semibold">
                <a href="{{ path('app_home') }}" class="transition-colors hover:text-secondary {{ route == 'app_home' ? 'text-secondary' : '' }}">Home</a>
                <a href="{{ path('app_sobre') }}" class="transition-colors hover:text-secondary {{ route == 'app_sobre' ? 'text-secondary' : '' }}">About</a>
                <a href="{{ path('app_inscricoes') }}" class="transition-colors hover:text-secondary {{ route == 'app_inscricoes' ? 'text-secondary' : '' }}">Registration</a>
                <a href="{{ path('app_submissao') }}" class="transition-colors hover:text-secondary {{ route == 'app_submissao' ? 'text-secondary' : '' }}">Call for Papers</a>
                <a href="{{ path('app_programa') }}" class="transition-colors hover:text-secondary {{ route == 'app_programa' ? 'text-secondary' : '' }}">Program</a>
                <a href="{{ path('app_palestrantes') }}" class="transition-colors hover:text-secondary {{ route in ['app_palestrantes', 'app_palestrante_detalhe'] ? 'text-secondary' : '' }}">Speakers</a>
                <a href="{{ path('app_patrocinadores') }}" class="transition-colors hover:text-secondary {{ route == 'app_patrocinadores' ? 'text-secondary' : '' }}">Sponsors</a>
                <a href="{{ path('app_local') }}" class="transition-colors hover:text-secondary {{ route == 'app_local' ? 'text-secondary' : '' }}">Venue</a>
                <a href="{{ path('app_contato') }}" class="transition-colors hover:text-secondary {{ route == 'app_contato' ? 'text-secondary' : '' }}">Contact</a>
            </nav>
            
            <button class="lg:hidden text-white hover:text-secondary focus:outline-none" aria-label="Toggle Menu">
                <span class="material-symbols-outlined text-3xl">menu</span>
            </button>
        </div>
    </header>

    {# Flash Messages Banner #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="container mx-auto px-6 mt-4">
                <div class="p-4 rounded-lg font-bold text-center {% if label == 'success' %}bg-green-100 text-green-800 border border-green-200{% else %}bg-red-100 text-red-800 border border-red-200{% endif %}">
                    {{ message }}
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    {# Main content block #}
    <main id="main-content" class="flex-grow">
        {% block body %}{% endblock %}
    </main>

    {# Dynamic Footer #}
    <footer class="bg-slate-900 text-slate-300 py-12 mt-auto">
        <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-8">

            <div>
                <a href="{{ path('app_home') }}" class="mb-4 inline-block">
                    <img src="{{ asset('fundecitrus-congresso-layout/assets/images/logo.png') }}" alt="IRCHLB 2027" class="h-12 w-auto">
                </a>
                <p class="text-sm mt-4">{{ event_config.title ?? 'VIII International Research Conference on Huanglongbing' }}. An event dedicated to science, innovation, and solutions for citriculture.</p>
            </div>

            <div>
                <h4 class="text-lg font-bold text-white mb-4">Quick Links</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="{{ path('app_sobre') }}" class="hover:text-secondary transition-colors">About the Conference</a></li>
                    <li><a href="{{ path('app_inscricoes') }}" class="hover:text-secondary transition-colors">Registration</a></li>
                    <li><a href="{{ path('app_submissao') }}" class="hover:text-secondary transition-colors">Submit Abstract</a></li>
                    <li><a href="{{ path('app_programa') }}" class="hover:text-secondary transition-colors">Schedule & Program</a></li>
                </ul>
            </div>

            <div>
                <h4 class="text-lg font-bold text-white mb-4">Help & Support</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="{{ path('app_contato') }}" class="hover:text-secondary transition-colors">Contact Us</a></li>
                    <li><a href="{{ path('app_contato', {'_fragment': 'faq'}) }}" class="hover:text-secondary transition-colors">FAQ</a></li>
                    <li><a href="{{ path('app_local') }}" class="hover:text-secondary transition-colors">Venue & Travel</a></li>
                    <li><a href="{{ path('app_patrocinadores') }}" class="hover:text-secondary transition-colors">Sponsorships</a></li>
                    {% for page in get_public_pages() %}
                        <li><a href="{{ path('app_page_content', {'slug': page.slug}) }}" class="hover:text-secondary transition-colors">{{ page.title }}</a></li>
                    {% endfor %}
                </ul>
            </div>

            <div>
                <h4 class="text-lg font-bold text-white mb-4">Newsletter</h4>
                <p class="text-sm mb-4">Stay updated on the latest conference news.</p>
                <form action="javascript:void(0);" class="flex" onsubmit="event.preventDefault(); alert('Thank you for subscribing!');">
                    <input type="email" placeholder="Your e-mail address"
                        class="w-full px-3 py-2 rounded-l-md text-slate-900 focus:outline-none" required>
                    <button type="submit"
                        class="bg-secondary text-primary font-bold px-4 py-2 rounded-r-md hover:brightness-110 transition-all flex items-center justify-center" aria-label="Subscribe">
                        <span class="material-symbols-outlined">send</span>
                    </button>
                </form>
            </div>

        </div>

        <div class="container mx-auto px-6 mt-12 pt-6 border-t border-slate-700 text-center text-sm">
            <p>&copy; {{ "now"|date("Y") }} IRCHLB. All rights reserved.</p>
            <p class="text-xs opacity-60 mt-1">Developed by Wab.com.br</p>
        </div>
    </footer>

    {# Mobile Menu Toggle Script #}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const menuBtn = document.querySelector('header button');
            const nav = document.querySelector('header nav');

            if (menuBtn && nav) {
                menuBtn.addEventListener('click', () => {
                    nav.classList.toggle('hidden');
                    nav.classList.toggle('flex');
                    nav.classList.toggle('flex-col');
                    nav.classList.toggle('absolute');
                    nav.classList.toggle('top-16');
                    nav.classList.toggle('left-0');
                    nav.classList.toggle('w-full');
                    nav.classList.toggle('bg-primary');
                    nav.classList.toggle('p-6');
                });
            }
        });
    </script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        AOS.init({duration: 800, once: true, offset: 100, easing: 'ease-out-quad'});
    </script>
</body>
</html>
